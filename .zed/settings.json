{
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
          ],
        },
      },
    },
